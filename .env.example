# =========================
# API KEYS
# =========================

DEEPGRAM_API_KEY=your_deepgram_api_key_here
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# =========================
# NVIDIA NIM CONFIG
# =========================

NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL_ID=gpt-oss-20b

# =========================
# SERVER CONFIG
# =========================

HOST=0.0.0.0
PORT=8000

# =========================
# WEBSOCKET
# =========================

WEBSOCKET_URL=ws://localhost:8000/ws

# =========================
# LATENCY TARGETS (ms)
# =========================

STT_LATENCY_TARGET=400
LLM_LATENCY_TARGET=800
TOTAL_LATENCY_TARGET=1500

# =========================
# CONTEXT ENGINE
# =========================

CONTEXT_WINDOW_SECONDS=60
MAX_TOKENS=150

# =========================
# DEBUG / DEV
# =========================

DEBUG=true
LOG_LEVEL=info